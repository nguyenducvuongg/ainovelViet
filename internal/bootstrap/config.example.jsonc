{
  // Provider và model được sử dụng theo mặc định.
  // ★ Giá trị của provider là một tên key trong providers bên dưới (một "con trỏ"), không phải tên giao thức——
  //   Thay đổi provider phải đảm bảo có một mục tương ứng trong providers, nếu không khi khởi động sẽ báo "chưa cấu hình thông tin xác thực".
  //   Sử dụng bảng /model khi đang chạy để chuyển đổi sẽ không tự động ghi đè ở đây.
  "provider": "openrouter",
  "model": "google/gemini-2.5-flash",

  // Thư viện thông tin xác thực của Provider. key tùy chỉnh, được sử dụng làm mục tiêu tham chiếu của trường provider ở trên.
  // Các provider đã biết (openai/anthropic/gemini/openrouter/deepseek/qwen/glm/grok/mimo/ollama/bedrock)
  // có thể bỏ qua type; proxy tùy chỉnh phải khai báo rõ ràng type để chỉ ra giao thức API.
  "providers": {
    "openrouter": {
      "api_key": "sk-or-v1-xxx",
      "base_url": "https://openrouter.ai/api/v1",
      // Tùy chọn. Khai báo các ứng cử viên cho bảng /model; nếu bỏ qua sẽ quay lại các mô hình cùng provider đã xuất hiện trong cấu hình.
      "models": ["google/gemini-3.0-flash", "google/gemini-3.1-pro"],
      // Tùy chọn. Truyền các tham số bổ sung cho mỗi yêu cầu của provider này (các tham số lấy mẫu như temperature/top_p/
      // min_p, hoặc các khóa đặc trưng của nhà sản xuất như chat_template_kwargs của nvidia), được hợp nhất nguyên văn vào thân yêu cầu.
      // Chỉ có hiệu lực cho các provider tương thích OpenAI (openrouter/deepseek/qwen/glm/grok/ollama…);
      // type:"openai" sẽ lọc theo danh sách trắng tham số chính thức. Giá trị do người dùng tự chịu trách nhiệm.
      "extra_body": { "temperature": 0.8, "min_p": 0.05 },
      // Tùy chọn. Cấu hình cấp provider, truyền trực tiếp cho lớp HTTP client (không phải thân yêu cầu), được sử dụng khi cần
      // tùy chỉnh User-Agent / headers / anthropic_beta của proxy.
      "extra": {
        "user_agent": "my-client/1.0",
        "headers": { "X-Custom-Client": "my-client" }
      }
    },
    "anthropic": {
      "api_key": "sk-ant-xxx",
      "models": ["claude-sonnet-4", "claude-opus-4"]
    },
    "ollama": {
      // ollama / bedrock / proxy tùy chỉnh với type rõ ràng có thể bỏ qua api_key
      // base_url cần có /v1 (điểm cuối tương thích OpenAI của ollama nằm dưới /v1)
      "base_url": "http://localhost:11434/v1",
      "models": ["qwen3:14b"]
    },
    "my-proxy": {
      // Proxy Anthropic tùy chỉnh. Khi proxy cần nhận diện client, sử dụng extra để truyền
      // user_agent / anthropic_beta / headers; base_url không cần có /v1.
      "type": "anthropic",
      "api_key": "sk-xxx",
      "base_url": "https://proxy.example.com",
      "models": ["claude-sonnet-4-6"],
      "extra": {
        "user_agent": "claude-code/2.1.183",
        "anthropic_beta": "claude-code-20250219",
        "headers": {
          "X-Stainless-Lang": "js",
          "X-Stainless-Package-Version": "0.94.0",
          "X-Stainless-Runtime": "node"
        }
      }
    }
  },

  // Tùy chọn. Ghi đè mô hình mặc định theo vai trò; các vai trò chưa cấu hình sẽ sử dụng model ở trên.
  // Vai trò: coordinator / architect / writer / editor. fallbacks được thử theo thứ tự khi mô hình chính thất bại.
  // Lưu ý: provider ở đây cũng là một "con trỏ", phải trỏ đến key tồn tại trong providers.
  // "roles": {
  //   "writer": {
  //     "provider": "anthropic",
  //     "model": "claude-sonnet-4",
  //     "fallbacks": [{ "provider": "openrouter", "model": "google/gemini-3.0-pro" }]
  //   },
  //   "architect": { "provider": "openrouter", "model": "google/gemini-3.1-pro" }
  // },

  // Phong cách viết: default / suspense / fantasy / romance.
  "style": "default"

  // Tùy chọn. Chỉ định rõ ràng kích thước cửa sổ được sử dụng để nén ngữ cảnh. Bỏ qua / 0 = tự động phân tích theo tên mô hình
  // (registry khớp sẽ dùng cửa sổ thực tế, không khớp sẽ dùng 200k làm mặc định). Nếu được cấu hình sẽ ưu tiên sử dụng: vừa có thể chỉ định
  // cửa sổ thực tế cho mô hình tùy chỉnh không tìm thấy trong registry, vừa có thể ghim cửa sổ danh nghĩa 1M ở mức 300k để kích hoạt nén sớm,
  // tránh nén trong vùng suy giảm sự chú ý. Chỉ ảnh hưởng đến ngưỡng nén, không thay đổi độ dài yêu cầu thực tế của API.
  // "context_window": 300000,

  // Tùy chọn. Ngân sách chi phí cho một cuốn sách (thư mục output), cầu chì treo máy. Chỉ kích hoạt khi book_usd > 0.
  // Cảnh báo nhưng không dừng máy khi chi phí tích lũy đạt warn_ratio; dừng máy một cách nhẹ nhàng sau khi tác nhân phụ hiện tại kết thúc
  // khi đạt 100% (nếu hard_stop=true thì sẽ dừng ngay lập tức khi vượt dòng). Sau khi dừng máy, tăng book_usd lên để tiếp tục chạy.
  // Lưu ý: Nếu mô hình tùy chỉnh không tìm thấy giá trong registry và provider không tự báo cáo cost, ngân sách sẽ vô hiệu.
  // "budget": {
  //   "book_usd": 50,
  //   "warn_ratio": 0.8,
  //   "hard_stop": false
  // },

  // Tùy chọn. Cảnh báo không giám sát, được kích hoạt theo mặc định (thông báo màn hình macOS osascript / Linux notify-send).
  // Sau khi cấu hình command sẽ chuyển sang lệnh tùy chỉnh (đẩy về điện thoại qua đây): các trường được truyền qua biến môi trường
  // $NOTIFY_TITLE / $NOTIFY_BODY / $NOTIFY_KIND / $NOTIFY_LEVEL, JSON hoàn chỉnh đồng thời được ghi vào stdin.
  // Bộ lọc sự kiện tùy chọn: run_end (hoàn thành/dừng) / repeat (trùng lặp hướng dẫn, nghi ngờ chạy không tải) / budget (ngân sách).
  // "notify": {
  //   "enabled": true,
  //   // Tiêu đề/nội dung chứa tiếng Việt và khoảng trắng, phải được truyền qua --data-urlencode, không thể nối vào đường dẫn URL hoặc header HTTP.
  //   // Bark (iOS):         "command": "curl -s --data-urlencode \"title=$NOTIFY_TITLE\" --data-urlencode \"body=$NOTIFY_BODY\" https://api.day.app/<key>"
  //   // ntfy (iOS/Android): "command": "curl -s -G --data-urlencode \"title=$NOTIFY_TITLE\" --data-urlencode \"message=$NOTIFY_BODY\" ntfy.sh/<topic>/publish"
  //   "events": ["run_end", "repeat", "budget"]
  // }
}
